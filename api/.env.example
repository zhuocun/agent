# Backend environment template. Copy to `.env` and edit for local dev.
# Every value below is a placeholder; `assert_prod_safe()` rejects these if
# you accidentally point `ENV=production` at this file.

# --- Runtime ---

# Deployment env. Controls assert_prod_safe() strictness.
# One of: dev | test | production
ENV=dev

# --- Database ---

# Async SQLAlchemy URL.
# Postgres (prod):  postgresql+asyncpg://user:pass@host:5432/db
# SQLite  (dev):    sqlite+aiosqlite:///./dev.sqlite3
DATABASE_URL=sqlite+aiosqlite:///./dev.sqlite3

# --- Sessions / cookies ---

# Secret used by itsdangerous to sign the `sid` cookie. MUST be overridden in
# prod (assert_prod_safe rejects the dev default).
SESSION_SECRET=dev-only-insecure-session-secret-change-me

# Session lifetime in seconds. Default is 30 days.
SESSION_MAX_AGE_SECONDS=2592000

# Cookie name on the wire.
COOKIE_NAME=sid

# Cookie hardening. Prod currently runs with secure+none for compatibility with
# the Fly API and Vercel rewrite/proxy path. In dev, false+lax.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# --- CORS ---

# Comma-separated list of allowed FE origins. Empty in dev is fine when the FE
# talks to the same host; prod must list every FE origin explicitly.
# Example: https://app.example.com,https://staging.example.com
CORS_ALLOWED_ORIGINS=

# Preflight cache TTL in seconds.
CORS_MAX_AGE=600

# --- Providers ---

# Provider backend. `fake` is deterministic and used by tests + local dev (keep
# it as the dev/test default — no key needed). `deepseek` is the canonical /
# main real provider (cost leader) and what prod runs. `anthropic` and `openai`
# are alternates. assert_prod_safe() rejects `fake` when ENV=production.
# For prod set: PROVIDER_BACKEND=deepseek
PROVIDER_BACKEND=fake

# --- Safety ---

# Baseline app-layer safety preflight. Default `disabled` preserves existing
# behavior. `local` checks user text and extracted text attachments against the
# comma-separated SAFETY_BLOCKLIST before any provider call or message write.
SAFETY_BACKEND=disabled
# SAFETY_BLOCKLIST=

# --- DeepSeek (canonical / main real provider) ---

# DeepSeek API key (required when PROVIDER_BACKEND=deepseek). DeepSeek is
# OpenAI-compatible, so the `deepseek` backend reuses the OpenAI client against
# the built-in default base_url (https://api.deepseek.com) — running
# PROVIDER_BACKEND=deepseek needs ONLY this key, no base_url/model gymnastics.
# Falls back to OPENAI_API_KEY when unset (an OpenAI-compatible key works under
# either name; the dedicated DEEPSEEK_API_KEY wins when both are present).
DEEPSEEK_API_KEY=

# Optional base_url override. The tier->model mapping (deepseek-v4-flash for
# fast/smart/auto, deepseek-v4-pro for pro, with raw reasoning tokens billed
# @ output rate) lives in the canonical registry (app/providers/tiers.py), not
# in env — same as the Anthropic table. You almost never need to set this.
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- Alternate providers (Anthropic / OpenAI) ---

# Anthropic API key (alternate; required when PROVIDER_BACKEND=anthropic). Used
# as the platform key; per-user BYOK keys live in the DB.
ANTHROPIC_API_KEY=

# OpenAI(-compatible) provider (alternate; used when PROVIDER_BACKEND=openai).
# Configured "OpenAI style": OPENAI_API_KEY is the platform key (per-user BYOK
# keys live in the DB).
OPENAI_API_KEY=

# OPENAI_BASE_URL is optional. Leave blank to use the official OpenAI endpoint
# (https://api.openai.com/v1). Override to point the SAME backend at any
# OpenAI-compatible endpoint: Azure OpenAI, OpenRouter, Ollama, vLLM, or a
# local server.
OPENAI_BASE_URL=

# Per-tier model overrides for the openai backend. Defaults shown below;
# override to bind any OpenAI-compatible model to a tier. Note: pricing tracks
# these defaults, so overriding a model makes the cost breakdown approximate.
# OPENAI_MODEL_FAST=gpt-4o-mini
# OPENAI_MODEL_SMART=gpt-4o
# OPENAI_MODEL_PRO=o1
# OPENAI_MODEL_AUTO=gpt-4o

# --- BYOK encryption ---

# AES-GCM key-encryption-key, base64-encoded 32 bytes. The default below is a
# known-bad dev sentinel (all zeros) that assert_prod_safe() refuses in
# production. Generate a fresh one with:
#   python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
BYOK_ENCRYPTION_KEK=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# Versioned-KEK rotation. `BYOK_KEK_VERSIONS` is a comma-separated list of
# `version:base64key` pairs, e.g. `1:<b64key1>,2:<b64key2>`. Empty (default)
# keeps the legacy single-KEK path above. `BYOK_CURRENT_KEK_VERSION=0` (default)
# writes legacy ciphertext (bit-compatible with rows on disk today); `>=1` writes
# the versioned format and looks up the active KEK in the registry. Reads
# dispatch on the on-disk header, so old rows stay decryptable through rotation.
# BYOK_KEK_VERSIONS=
# BYOK_CURRENT_KEK_VERSION=0

# --- Rate limiting (slowapi) ---

# Per-route limits in slowapi format `<count>/<window>`. In-process MemoryStorage
# (single uvicorn worker). Multi-worker prod needs a shared store; future.
# RATE_LIMIT_MESSAGES=30/minute
# RATE_LIMIT_UPGRADE=5/minute

# --- Usage budget ---

# Cost-based budget cap in USD per calendar-month period. When a user's
# accumulated cost for the period reaches this value, the next platform-key turn
# is refused with a 429 PLATFORM_BUDGET_EXCEEDED envelope. `<= 0` means disabled /
# unlimited (the default). BYOK turns (the user's own provider key) are exempt.
# USAGE_BUDGET_USD=0

# --- Tools + agentic mode ---

# Backend-side tool calling + human-in-the-loop (HITL) approval. DEFAULT-OFF
# feature flag — a hard safety gate around the agent loop. When false, the
# provider advertises no tools and the streaming path is byte-for-byte
# identical to a pre-tools build. When true, the handler drives a bounded
# agent loop over the provider's tool calls, executing side-effect-free tools
# inline and pausing (`awaiting_approval`) on approval-gated tools until a
# follow-up `toolApproval` resume POST applies the decision.
TOOLS_ENABLED=false

# Agentic mode (multi-agent orchestration). DEFAULT-OFF feature flag — a hard
# safety gate around the orchestrator, layered ON TOP of TOOLS_ENABLED. When
# false, an `agenticMode` on the send request is ignored entirely and the
# streaming path is byte-for-byte identical to a pre-agentic build. When true,
# a send carrying `agenticMode` drives the orchestrator instead of the bare
# agent loop. Requires TOOLS_ENABLED=true — assert_prod_safe() refuses the
# inconsistent combination at boot.
AGENTIC_ENABLED=false

# Hard upper bound on the number of fan-out workers a single deep-research run
# may spawn (the planner truncates its decomposition to this many
# sub-questions). Bounds parallel provider spend per turn.
# AGENTIC_MAX_WORKERS=4

# Max number of workers allowed to run concurrently (the fan-out semaphore
# width). Keeps in-flight provider calls per turn bounded independently of the
# total worker count.
# AGENTIC_MAX_CONCURRENCY=3

# Max orchestration depth (a worker spawning its own sub-workers). M1/M2 run a
# single level; reserved for deeper recursion in a later milestone.
# AGENTIC_MAX_DEPTH=1

# Per-run cost budget (USD) surfaced on the `run_cost` wire event as the cap.
# Scaffold for the M3 budget/admission control; not yet enforced.
# AGENTIC_RUN_BUDGET_USD=1.0

# Plan-approval gate (M3). When true, a deep-research plan pauses for human
# approval before fan-out. Scaffold default-off; the hook is a no-op for now.
# AGENTIC_PLAN_APPROVAL=false

# Answer verifier (M3). When true, the synthesized answer is cross-checked by
# AGENTIC_VERIFIER_N independent passes. Scaffold default-off; the hook is a
# no-op for now.
# AGENTIC_VERIFIER=false
# AGENTIC_VERIFIER_N=3

# --- Observability ---

# Sentry error reporting. Unset -> no-op (production warns at boot but starts).
# SENTRY_DSN=

# OTel tracing via OTLP/HTTP. Unset -> no tracer is registered, instrumentation
# is skipped. `OTEL_SERVICE_NAME` is the `service.name` resource attribute.
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_SERVICE_NAME=api
