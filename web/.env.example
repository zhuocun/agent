# Browser-visible API base URL.
#
# Production: leave empty so requests use same-origin /api/* and Next rewrites
# them to Fly via next.config.ts. This keeps auth cookies first-party.
NEXT_PUBLIC_API_BASE_URL=

# Local direct-CORS option: point the browser straight at the FastAPI dev
# server instead of using the Next rewrite.
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Local same-origin proxy option: keep NEXT_PUBLIC_API_BASE_URL empty and point
# the Next rewrite at your local FastAPI dev server.
# BE_ORIGIN=http://localhost:8000
