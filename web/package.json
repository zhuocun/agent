{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "check:bundle": "node scripts/check-bundle-size.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install --with-deps chromium",
    "dev:coverage": "COVERAGE=1 next dev --webpack",
    "test:e2e:coverage": "rm -rf coverage && { COVERAGE=1 playwright test --retries=1; status=$?; pnpm run coverage:report; exit $status; }",
    "coverage:report": "nyc report --reporter=text-summary --reporter=text --reporter=lcov --reporter=html --temp-dir coverage/.nyc_output --report-dir coverage"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "mermaid": "^11.12.2",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.8.1",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@playwright/test": "1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-loader": "^10.1.1",
    "babel-plugin-istanbul": "^8.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "nyc": "^18.0.0",
    "playwright": "^1.60.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
